[core]
  pager = delta

[interactive]
  diffFilter = delta --color-only

[delta]
  navigate = true
  light = false
  side-by-side = true
  line-numbers = true
  syntax-theme = Dracula
  hunk-header-style = file line-number syntax

[merge]
  conflictstyle = zdiff3

[alias]
  diff-inline = -c delta.side-by-side=false diff
